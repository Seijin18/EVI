POSTGRES_DB=evidb
POSTGRES_USER=evi
POSTGRES_PASSWORD=
WINDMILL_DB_USER=windmill
WINDMILL_DB_PASSWORD=windmill
OLLAMA_BASE_URL=http://host.docker.internal:11434
QDRANT_URL=http://qdrant:6333
DATABASE_URL=postgresql://evi:changeme@localhost:5432/evidb

# Bearer for Windmill jobs (Account settings → Tokens); not Google OAuth
# WINDMILL_TOKEN=
# Windmill resource path for Calendar OAuth (e.g. u/you/well_educated_gcal)
# WINDMILL_GCAL_RESOURCE=u/you/gcal
# Calendar display name (EVI) or API id (primary, or …@group.calendar.google.com)
# WINDMILL_CALENDAR_ID=EVI
# WINDMILL_GTASKS_RESOURCE=u/you/gtasks
# WINDMILL_GMAIL_RESOURCE=u/you/gmail

# Telegram digest for pending WhatsApp commitments (optional)
# TELEGRAM_BOT_TOKEN=from @BotFather
# TELEGRAM_CHAT_ID= numeric chat.id from getUpdates (private chat = your user id)
# Async URL from script Triggers — optional ?token=… if WINDMILL_TOKEN unset
WINDMILL_WEBHOOK_CALENDAR=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/schedule_event
WINDMILL_WEBHOOK_TASKS=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/create_task
WINDMILL_WEBHOOK_EMAIL=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/summarize_inbox
WINDMILL_WEBHOOK_TELEGRAM=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/telegram_to_evi

EVOLUTION_API_KEY=evi-dev-key
EVOLUTION_SERVER_URL=http://localhost:8082
EVOLUTION_INSTANCE_NAME=evi
EVOLUTION_WEBHOOK_URL=http://agent-api:8000/webhooks/evolution

# WhatsApp webhook filters (agent-api)
EVI_WHATSAPP_MAX_PER_WEBHOOK=10
EVI_WHATSAPP_MAX_AGE_HOURS=24
EVI_WHATSAPP_INCOMING_ONLY=true
EVI_WHATSAPP_SKIP_GROUPS=true
# Com whitelist, só estes JIDs de grupo (@g.us) passam; demais grupos ignorados.
# Requer groupsIgnore=false na Evolution — rode ./scripts/setup-evolution.sh após definir.
# EVI_WHATSAPP_GROUP_WHITELIST=120363012345678901@g.us,120363098765432109@g.us
EVI_WHATSAPP_DEDUPE_IDS=true

EVI_API_KEY=
EVI_PROJECT_ROOT=/home/marshibs/Projects/EVI
EVI_API_URL=http://localhost:8002
EVI_HOST_WATCH_PREFIX=/home/marshibs/Projects/EVI/watched_folders
EVI_CONTAINER_WATCH_PREFIX=/watched_folders
EVI_NOTES_DIR=/watched_folders/inbox_ia
# Host scripts/tests; Docker agent-api always writes to ./logs (mounted as /logs)
EVI_LOG_DIR=/home/marshibs/Projects/EVI/logs

# Google OAuth (Windmill Resources)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Windmill workspace variables (UI): EVI_AGENT_URL, EVI_API_KEY for telegram_to_evi
