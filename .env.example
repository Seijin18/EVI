POSTGRES_DB=evidb
POSTGRES_USER=evi
POSTGRES_PASSWORD=
WINDMILL_DB_USER=windmill
WINDMILL_DB_PASSWORD=windmill
# ── LLM provider ─────────────────────────────────────────────────────────────
# EVI_LLM_PROVIDER   = ollama (default) | gemini | openai | anthropic
# EVI_EMBED_PROVIDER = ollama (default) | google | openai
EVI_LLM_PROVIDER=ollama
EVI_EMBED_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
# Gemini (EVI_LLM_PROVIDER=gemini or EVI_EMBED_PROVIDER=google)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=models/gemini-embedding-001
# OpenAI (EVI_LLM_PROVIDER=openai or EVI_EMBED_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# Anthropic (EVI_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-3-5-haiku-20241022
# ─────────────────────────────────────────────────────────────────────────────
# Orchestration backend (EVI_ORCHESTRATOR=windmill is the only shipped backend)
EVI_ORCHESTRATOR=windmill
# WhatsApp messaging backend (EVI_WHATSAPP_PROVIDER=evolution is the only shipped backend)
EVI_WHATSAPP_PROVIDER=evolution
QDRANT_URL=http://qdrant:6333
DATABASE_URL=postgresql://evi:changeme@localhost:5432/evidb

# Bearer for Windmill jobs (Account settings → Tokens); not Google OAuth
# WINDMILL_TOKEN=
# Retry Windmill 401/422 once (OAuth resource refresh on cold start)
EVI_WINDMILL_RETRY_ATTEMPTS=2
EVI_WINDMILL_RETRY_DELAY_SEC=2
# Windmill resource path for Calendar OAuth (e.g. u/you/well_educated_gcal)
# WINDMILL_GCAL_RESOURCE=u/you/gcal
# Calendar display name (EVI) or API id (primary, or …@group.calendar.google.com)
# WINDMILL_CALENDAR_ID=EVI
# IANA timezone for Calendar events (wall clock, not UTC)
# EVI_TIMEZONE=America/Sao_Paulo

# JSONL logs (telegram, evolution) — keep entries up to N days
# EVI_LOG_MAX_AGE_DAYS=7
# EVI_LOG_MAX_LINES=5000
# EVI_HARNESS_LOG_MAX_AGE_DAYS=1
# Google Tasks — resource Windmill tipo gtasks (NÃO usar gcloud; ver windmill/README.md)
# WINDMILL_GTASKS_RESOURCE=u/you/evi_tasks
# Gmail via Windmill gmail OAuth. See windmill/README.md
# WINDMILL_GMAIL_RESOURCE=u/you/gmail
# WINDMILL_WEBHOOK_EMAIL_DELETE=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/delete_emails
# WINDMILL_WEBHOOK_EMAIL_DELETE_QUERY=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/delete_emails_by_query

# Cloudflare named tunnel (free) — stable Telegram webhook hostname
# CLOUDFLARE_TUNNEL_NAME=evi-windmill
# CLOUDFLARE_TUNNEL_HOSTNAME=wm.example.com

# Telegram — polling (recommended home): no tunnel/domain. webhook = Windmill+tunnel
# TELEGRAM_MODE=polling
# TELEGRAM_BOT_TOKEN=from @BotFather
# TELEGRAM_CHAT_ID= numeric chat.id from getUpdates (digest + sendMessage default)
# Setup polling: ./scripts/evi-telegram-polling-setup.sh
# Async URL from script Triggers — optional ?token=… if WINDMILL_TOKEN unset
WINDMILL_WEBHOOK_CALENDAR=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/schedule_event
WINDMILL_WEBHOOK_LIST_EVENTS=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/list_events
WINDMILL_WEBHOOK_TASKS=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/create_task
WINDMILL_WEBHOOK_LIST_TASKS=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/list_tasks
WINDMILL_WEBHOOK_EMAIL=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/summarize_inbox
WINDMILL_WEBHOOK_TELEGRAM=http://windmill-server:8000/api/w/evi/jobs/run/p/f/integrations/telegram_to_evi

EVOLUTION_API_KEY=evi-dev-key
# Host/scripts (setup-evolution.sh). agent-api no compose usa http://evolution-api:8080
EVOLUTION_SERVER_URL=http://localhost:8082
EVOLUTION_INSTANCE_NAME=evi
EVOLUTION_WEBHOOK_URL=http://agent-api:8000/webhooks/evolution

# EVI agent runtime v3 (OpenClaw-inspired)
EVI_WORKSPACE=/home/marshibs/Projects/EVI/EVI_WORKSPACE
# EVI_DIRECT_HANDLERS=false
# EVI_HEARTBEAT_ENABLED=false

# WhatsApp webhook filters (agent-api)
EVI_WHATSAPP_MAX_PER_WEBHOOK=10
EVI_WHATSAPP_MAX_AGE_HOURS=24
EVI_WHATSAPP_REQUIRE_TS=true
# EVI_WHATSAPP_PROCESS_AFTER=2026-06-17T05:00:00+00:00
EVI_WHATSAPP_INCOMING_ONLY=true
EVI_WHATSAPP_SKIP_GROUPS=true
# Com whitelist, só estes JIDs de grupo (@g.us) passam; demais grupos ignorados.
# Requer groupsIgnore=false na Evolution — rode ./scripts/setup-evolution.sh após definir.
# EVI_WHATSAPP_GROUP_WHITELIST=120363012345678901@g.us,120363098765432109@g.us
EVI_WHATSAPP_DEDUPE_IDS=true
# Backfill de histórico para learn_whatsapp_contact (Evolution findMessages)
EVI_BACKFILL_MAX_MESSAGES=200
EVI_BACKFILL_INCLUDE_FROM_ME=true
# LLM fallback when heuristic extract returns nothing (requires Ollama)
# EVI_WHATSAPP_LLM_EXTRACT=false
# EVI_WHATSAPP_LLM_MIN_CONFIDENCE=0.6
# EVI_WHATSAPP_LLM_TIMEOUT_SEC=30
# Chat de comando EVI (grupo solo ou Mensagens para mim). Respostas com prefixo [EVI]
# EVI_WHATSAPP_CONTROL_JIDS=5511999999999@s.whatsapp.net
# EVI_WHATSAPP_REPLY_PREFIX=[EVI] 
# Digest/review: telegram,whatsapp (whatsapp exige CONTROL_JIDS)
EVI_NOTIFY_CHANNELS=telegram

# Prometheus exposition at GET /metrics (no prometheus container in compose)
EVI_METRICS_ENABLED=true

# Long-term memory (Etapa 5a) — cold FS per WhatsApp/Telegram JID
EVI_CONTACT_MEMORY_DIR=/data/contact_memory
# Host bind: ./data/contact_memory (compose volume on agent-api)

# Knowledge graph (Etapa 5b, optional) — docker compose --profile graph up -d neo4j
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=changeme

EVI_API_KEY=
EVI_PROJECT_ROOT=/home/marshibs/Projects/EVI
EVI_API_URL=http://localhost:8002
EVI_HOST_WATCH_PREFIX=/home/marshibs/Projects/EVI/watched_folders
EVI_CONTAINER_WATCH_PREFIX=/watched_folders
EVI_NOTES_DIR=/watched_folders/inbox_ia
# Host scripts/tests; Docker agent-api always writes to ./logs (mounted as /logs)
EVI_LOG_DIR=/home/marshibs/Projects/EVI/logs

# Google OAuth (Windmill Resources)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Windmill workspace variables (UI): EVI_AGENT_URL, EVI_API_KEY for telegram_to_evi
